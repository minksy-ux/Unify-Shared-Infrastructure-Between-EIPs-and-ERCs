From c759b5ba94971147d48096408de6a4728df36834 Mon Sep 17 00:00:00 2001
From: Minsky <minksy099@gmail.com>
Date: Wed, 15 Jul 2026 10:00:39 +0000
Subject: [PATCH] CI: pin artifact actions and restore trigger concurrency

---
 .github/workflows/auto-review-bot.yml     | 2 +-
 .github/workflows/auto-review-trigger.yml | 6 +++++-
 2 files changed, 6 insertions(+), 2 deletions(-)

diff --git a/.github/workflows/auto-review-bot.yml b/.github/workflows/auto-review-bot.yml
index 0fae839..c816c79 100644
--- a/.github/workflows/auto-review-bot.yml
+++ b/.github/workflows/auto-review-bot.yml
@@ -21,7 +21,7 @@ jobs:
       - name: Fetch PR Number
         id: fetch-pr-number
         continue-on-error: true
-        uses: actions/download-artifact@v4
+        uses: actions/download-artifact@d3f86a106a0bac45b974a628896c90dbdf5c8093 # v4
         with:
           name: pr-number
           run-id: ${{ github.event.workflow_run.id }}
diff --git a/.github/workflows/auto-review-trigger.yml b/.github/workflows/auto-review-trigger.yml
index 928a690..5b707b7 100644
--- a/.github/workflows/auto-review-trigger.yml
+++ b/.github/workflows/auto-review-trigger.yml
@@ -14,6 +14,10 @@ on:
 
 name: Auto Review Bot Trigger
 
+concurrency:
+  group: ${{ github.workflow }}-${{ github.event.pull_request.number || github.ref }}
+  cancel-in-progress: true
+
 permissions:
   contents: read
   pull-requests: read
@@ -76,7 +80,7 @@ jobs:
 
       - name: Upload PR Number Artifact
         if: steps.check_pr_number.outputs.exists == 'true'
-        uses: actions/upload-artifact@v4
+        uses: actions/upload-artifact@ea165f8d65b6e75b540449e92b4886f43607fa02 # v4
         with:
           name: pr-number
           path: pr-number.txt
-- 
2.53.0

